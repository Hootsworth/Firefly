{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firefly",
  "version": "1.0.0",
  "identifier": "app.firefly.diagnostics",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm start",
    "devUrl": "http://127.0.0.1:4173/app.html",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Firefly",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "url": "app.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Expected vs observed system-path diagnostics.",
    "longDescription": "Firefly models expected transfer and processing time, compares observed deltas, and explains likely hardware or topology constraints."
  }
}
